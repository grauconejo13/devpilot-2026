# Auth Service Environment Variables
# Copy this file to .env and fill in your values

# Server port (auth subgraph — do NOT use 4000, that's the gateway)
PORT=4001

# MongoDB connection string — do NOT include the database name here
# The service will connect to the "authdb" database automatically
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/

# Session secret — must be a long random string (32+ characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_this_with_a_long_random_secret_minimum_32_characters

# Environment
NODE_ENV=development
