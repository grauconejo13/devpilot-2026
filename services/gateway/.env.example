# Apollo Gateway Environment Variables
# Copy this file to .env and fill in your values

# Gateway port — must match the Apollo Client URI in apps/shell-app/src/apollo/client.ts
PORT=4000

# Subgraph URLs — update if running on different ports
AUTH_SERVICE_URL=http://localhost:4001/graphql
PROJECTS_SERVICE_URL=http://localhost:4002/graphql

# NOTE: The AI Review service is a REST-only service — do NOT add it here as a subgraph

# Environment
NODE_ENV=development
